<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>매뉴얼 어노테이션 통합 툴</title>
  <style>
    :root {
      --bg: #f5f5f5;
      --surface: #ffffff;
      --border: #e0d8d0;
      --accent: #f97316;
      --accent2: #ea580c;
      --accent-glow: rgba(249,115,22,.15);
      --text: #1a1008;
      --text-muted: #7a6a58;
      --header-h: 56px;
      --panel-label: #fff4ed;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Segoe UI', 'Noto Sans KR', sans-serif;
      background: var(--bg);
      color: var(--text);
      height: 100vh;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    /* ─── HEADER ─── */
    header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: var(--header-h);
      background: var(--surface);
      border-bottom: 2px solid var(--accent);
      display: flex;
      align-items: center;
      padding: 0 20px;
      gap: 20px;
      z-index: 100;
      box-shadow: 0 2px 18px rgba(249,115,22,.25);
    }

    .header-title {
      font-size: 15px;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: .5px;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .header-title span {
      color: var(--text-muted);
      font-weight: 400;
    }

    .site-label {
      font-size: 12px;
      color: var(--text-muted);
      white-space: nowrap;
      flex-shrink: 0;
    }

    #siteInput {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text);
      font-size: 13px;
      padding: 6px 12px;
      width: 220px;
      outline: none;
      transition: border-color .2s;
    }
    #siteInput:focus {
      border-color: var(--accent);
    }
    #siteInput::placeholder {
      color: var(--text-muted);
    }

    .btn {
      background: var(--accent);
      color: #ffffff;
      border: none;
      border-radius: 6px;
      padding: 6px 16px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: opacity .2s, box-shadow .2s;
      white-space: nowrap;
      flex-shrink: 0;
      box-shadow: 0 0 10px rgba(249,115,22,.3);
    }
    .btn:hover { opacity: .85; box-shadow: 0 0 18px rgba(249,115,22,.55); }

    .date-display {
      font-size: 12px;
      color: var(--text-muted);
      background: var(--panel-label);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 5px 10px;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .date-display strong { color: var(--accent2); }

    /* ─── MAIN LAYOUT ─── */
    .workspace {
      margin-top: var(--header-h);
      display: flex;
      height: calc(100vh - var(--header-h));
      width: 100%;
    }

    /* LEFT half */
    .left-panel {
      width: 50%;
      display: flex;
      flex-direction: column;
      border-right: 2px solid var(--accent);
    }

    /* LEFT TOP — debug tool */
    .left-top {
      height: 50%;
      border-bottom: 2px solid var(--accent);
      position: relative;
    }

    /* LEFT BOTTOM — 3 equal columns */
    .left-bottom {
      height: 50%;
      display: flex;
    }

    .sub-frame {
      flex: 1;
      border-right: 1px solid var(--border);
      position: relative;
    }
    .sub-frame:last-child { border-right: none; }

    /* RIGHT half */
    .right-panel {
      width: 50%;
      position: relative;
    }

    /* ─── PANEL LABELS ─── */
    .panel-label {
      position: absolute;
      top: 6px;
      left: 8px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .8px;
      text-transform: uppercase;
      color: var(--accent);
      background: var(--panel-label);
      border: 1px solid var(--accent);
      border-radius: 4px;
      padding: 2px 7px;
      z-index: 10;
      pointer-events: none;
      box-shadow: 0 0 6px rgba(249,115,22,.2);
    }

    /* ─── IFRAMES ─── */
    iframe {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
      background: #f0f0f0;
    }

    /* ─── PLACEHOLDER (before siteID entered) ─── */
    .placeholder {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 10px;
      color: var(--text-muted);
      font-size: 13px;
      background: #fafafa;
      z-index: 5;
    }
    .placeholder svg {
      opacity: .3;
      color: var(--accent);
    }
    .placeholder p {
      opacity: .6;
    }

    /* ─── COPY BUTTON ─── */
    .btn-copy {
      display: flex;
      align-items: center;
      gap: 6px;
      background: #fff;
      color: var(--accent);
      border: 1.5px solid var(--accent);
      border-radius: 6px;
      padding: 5px 14px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      flex-shrink: 0;
      transition: background .15s, color .15s, box-shadow .15s;
    }
    .btn-copy:hover {
      background: var(--accent);
      color: #fff;
      box-shadow: 0 0 12px rgba(249,115,22,.4);
    }
    .btn-copy kbd {
      font-family: inherit;
      font-size: 11px;
      font-weight: 700;
      background: var(--accent);
      color: #fff;
      border-radius: 3px;
      padding: 1px 5px;
      letter-spacing: .5px;
    }
    .btn-copy:hover kbd {
      background: rgba(255,255,255,.3);
    }

    /* ─── COPY TOAST ─── */
    .copy-toast {
      position: fixed;
      top: 66px;
      left: 50%;
      transform: translateX(-50%) translateY(-6px);
      background: #1a1008;
      color: #fff;
      font-size: 13px;
      font-weight: 600;
      padding: 7px 18px;
      border-radius: 20px;
      opacity: 0;
      pointer-events: none;
      transition: opacity .2s, transform .2s;
      z-index: 200;
      white-space: nowrap;
    }
    .copy-toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  </style>
</head>
<body>

<!-- ═══════════════════════════ HEADER ═══════════════════════════ -->
<header>
  <div class="header-title">매뉴얼 어노테이션 통합 툴 <span>/ Manual Annotation Integrator</span></div>
  <div class="site-label">Site ID</div>
  <input id="siteInput" type="text" placeholder="예: jinhaejoy_1x9" />
  <button class="btn" onclick="applyAll()">적용</button>
  <button class="btn-copy" id="copyBtn" onclick="copySiteID()" title="단축키: X">
    <span id="copyBtnLabel">Site ID 복사하기</span>
    <kbd>[X]</kbd>
  </button>
  <div id="copyToast" class="copy-toast">✓ 복사됨!</div>
  <div class="date-display">기준 날짜: <strong id="dateDisplay">—</strong></div>
</header>

<!-- ═══════════════════════════ WORKSPACE ═══════════════════════════ -->
<div class="workspace">

  <!-- LEFT PANEL -->
  <div class="left-panel">

    <!-- LEFT TOP: Debug Tool -->
    <div class="left-top">
      <div class="panel-label">🛠 Debug Tool</div>
      <div class="placeholder" id="ph-debug">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
        <p>Site ID를 입력 후 [적용] 버튼을 누르세요</p>
      </div>
      <iframe id="frame-debug" src="about:blank" style="display:none;"></iframe>
    </div>

    <!-- LEFT BOTTOM: 3 sub-frames -->
    <div class="left-bottom">
      <div class="sub-frame">
        <div class="panel-label">⚙ Worker 1</div>
        <div class="placeholder" id="ph-w1">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
          <p id="ph-w1-msg">인증 중...</p>
        </div>
        <iframe id="frame-w1" src="about:blank" style="display:none;"></iframe>
      </div>
      <div class="sub-frame">
        <div class="panel-label">⚙ Worker 2</div>
        <div class="placeholder" id="ph-w2">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
          <p id="ph-w2-msg">인증 중...</p>
        </div>
        <iframe id="frame-w2" src="about:blank" style="display:none;"></iframe>
      </div>
      <div class="sub-frame">
        <div class="panel-label">⚙ Worker 3</div>
        <div class="placeholder" id="ph-w3">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
          <p id="ph-w3-msg">인증 중...</p>
        </div>
        <iframe id="frame-w3" src="about:blank" style="display:none;"></iframe>
      </div>
    </div>

  </div>

  <!-- RIGHT PANEL: Debug Image Viewer -->
  <div class="right-panel">
    <div class="panel-label">🖼 Sync Image Viewer</div>
    <div class="placeholder" id="ph-img">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      <p>Site ID를 입력 후 [적용] 버튼을 누르세요</p>
    </div>
    <iframe id="frame-img" src="about:blank" style="display:none;"></iframe>
  </div>

</div>

<script>
  // ── 오늘 기준 주말 제외 이전 날짜 계산 ──
  function getLastWorkday() {
    const d = new Date();
    d.setHours(0, 0, 0, 0);
    d.setDate(d.getDate() - 1);
    while (d.getDay() === 0 || d.getDay() === 6) {
      d.setDate(d.getDate() - 1);
    }
    return d;
  }

  function formatDate(d) {
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${day}`;
  }

  const workday = getLastWorkday();
  const dateStr = formatDate(workday);
  document.getElementById('dateDisplay').textContent = dateStr;

  // ── Worker Basic Auth 사전 인증 ──
  // fetch로 Authorization 헤더를 먼저 보내 브라우저 인증 캐시를 세팅한 뒤 iframe 로드
  const WORKER_URL = 'http://54.211.199.218:8080/';
  const WORKER_CRED = ':storyline0214$';   // 아이디없음:비밀번호

  function loadWorkers() {
    const headers = new Headers();
    headers.set('Authorization', 'Basic ' + btoa(WORKER_CRED));

    // 한 번만 fetch해서 브라우저 인증 캐시에 등록
    fetch(WORKER_URL, { method: 'GET', headers, mode: 'no-cors', credentials: 'include' })
      .then(() => {
        // 인증 캐시가 잡힌 뒤 3개 iframe 모두 로드
        ['w1','w2','w3'].forEach(id => {
          const ph  = document.getElementById(`ph-${id}`);
          const frm = document.getElementById(`frame-${id}`);
          frm.src = WORKER_URL;
          frm.style.display = 'block';
          ph.style.display  = 'none';
        });
      })
      .catch(() => {
        // fetch 자체가 막혀도(mixed-content 등) 일단 iframe 직접 시도
        ['w1','w2','w3'].forEach(id => {
          const msg = document.getElementById(`ph-${id}-msg`);
          if (msg) msg.textContent = '직접 연결 시도 중...';
          const ph  = document.getElementById(`ph-${id}`);
          const frm = document.getElementById(`frame-${id}`);
          frm.src = WORKER_URL;
          frm.style.display = 'block';
          ph.style.display  = 'none';
        });
      });
  }

  // 페이지 로드 직후 인증 시도
  window.addEventListener('DOMContentLoaded', loadWorkers);

  // ── 적용 ──
  function applyAll() {
    const site = document.getElementById('siteInput').value.trim();
    if (!site) {
      alert('Site ID를 입력해 주세요.');
      return;
    }

    // 복사 버튼 라벨 업데이트
    document.getElementById('copyBtnLabel').textContent = `${site} 복사하기`;

    // 1. Sync Image Viewer (right)
    const imgUrl = `https://playtag-debugging-tool.vercel.app/sync-images.html?mode=all&date=${dateStr}&site=${encodeURIComponent(site)}`;
    const fImg = document.getElementById('frame-img');
    fImg.src = imgUrl;
    fImg.style.display = 'block';
    document.getElementById('ph-img').style.display = 'none';

    // 2. Debug Tool (left-top)
    const debugUrl = `https://playtag-debugging-tool.vercel.app/?site=${encodeURIComponent(site)}&date=${dateStr}`;
    const fDebug = document.getElementById('frame-debug');
    fDebug.src = debugUrl;
    fDebug.style.display = 'block';
    document.getElementById('ph-debug').style.display = 'none';
  }

  // Enter 키 지원
  document.getElementById('siteInput').addEventListener('keydown', e => {
    if (e.key === 'Enter') applyAll();
  });

  // ── Site ID 복사 ──
  function copySiteID() {
    const site = document.getElementById('siteInput').value.trim();
    if (!site) {
      alert('먼저 Site ID를 입력하고 [적용]을 눌러주세요.');
      return;
    }
    navigator.clipboard.writeText(site).then(() => {
      const toast = document.getElementById('copyToast');
      toast.textContent = `✓ "${site}" 복사됨!`;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 1800);
    });
  }

  // ── 단축키 X ──
  document.addEventListener('keydown', e => {
    if (document.activeElement === document.getElementById('siteInput')) return;
    if (e.key === 'x' || e.key === 'X') copySiteID();
  });
</script>
</body>
</html>
